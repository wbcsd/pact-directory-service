{
  "name": "pact-data-model",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./common": "./src/common/validate.ts",
    "./common/*": "./src/common/*.ts",
    "./v2_0": "./src/v2_0/index.ts",
    "./v2_0/*": "./src/v2_0/*.ts",
    "./v2_1": "./src/v2_1/index.ts",
    "./v2_1/*": "./src/v2_1/*.ts",
    "./v2_2": "./src/v2_2/index.ts",
    "./v2_2/*": "./src/v2_2/*.ts",
    "./v2_3": "./src/v2_3/index.ts",
    "./v2_3/*": "./src/v2_3/*.ts",
    "./v3_0": "./src/v3_0/index.ts",
    "./v3_0/*": "./src/v3_0/*.ts"
  },
  "typesVersions": {
    "*": {
      "common": ["./src/common/validate.ts"],
      "common/*": ["./src/common/*.ts"],
      "v2_0": ["./src/v2_0/index.ts"],
      "v2_0/*": ["./src/v2_0/*.ts"],
      "v2_1": ["./src/v2_1/index.ts"],
      "v2_1/*": ["./src/v2_1/*.ts"],
      "v2_2": ["./src/v2_2/index.ts"],
      "v2_2/*": ["./src/v2_2/*.ts"],
      "v2_3": ["./src/v2_3/index.ts"],
      "v2_3/*": ["./src/v2_3/*.ts"],
      "v3_0": ["./src/v3_0/index.ts"],
      "v3_0/*": ["./src/v3_0/*.ts"]
    }
  },
  "scripts": {
    "generate-schemas": "tsx scripts/generate-schemas.ts",
    "generate-types": "tsx scripts/generate-types.ts"
  },
  "dependencies": {
    "@types/js-yaml": "^4.0.9",
    "ajv": "^8.17.1",
    "ajv-errors": "^3.0.0",
    "ajv-formats": "^3.0.1",
    "js-yaml": "^4.1.1"
  }
}
{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "rootDir": "src",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "useUnknownInCatchVariables": false,
    "tsBuildInfoFile": "dist/tsconfig.tsbuildinfo",
    "types": ["jest", "node"],
    "paths": {
      "@src/*": ["./src/*"],
      "pact-data-model": ["../../packages/pact-data-model/src/index.ts"],
      "pact-data-model/*": ["../../packages/pact-data-model/src/*"],
      "pact-api-client": ["../../packages/pact-api-client/src/index.ts"],
      "pact-api-client/*": ["../../packages/pact-api-client/src/*"]
    }
  },
  "include": ["src/**/*.ts"]
}

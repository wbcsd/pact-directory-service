# Node Management
# ======================

@organizationId = 9
@nodeId = 1
@targetNodeId = 2
@invitationId = 1
@connectionId = 1

### Create a node for an organization
POST {{baseUrl}}/directory/organizations/{{organizationId}}/nodes
Authorization: Bearer {{jwtToken}}
Content-Type: application/json

{
  "name": "Production Node",
  "type": "internal"
}

### Create an external node for an organization
POST {{baseUrl}}/directory/organizations/{{organizationId}}/nodes
Authorization: Bearer {{jwtToken}}
Content-Type: application/json

{
  "name": "External Partner Node",
  "type": "external",
  "apiUrl": "https://partner.example.com/api"
}

### Get a specific node by ID
GET {{baseUrl}}/directory/nodes/{{nodeId}}
Authorization: Bearer {{jwtToken}}
Content-Type: application/json

### Update a node
PUT {{baseUrl}}/directory/nodes/{{nodeId}}
Authorization: Bearer {{jwtToken}}
Content-Type: application/json

{
  "name": "Updated Node Name",
  "status": "active"
}

### Update an external node's API URL
PUT {{baseUrl}}/directory/nodes/{{nodeId}}
Authorization: Bearer {{jwtToken}}
Content-Type: application/json

{
  "apiUrl": "https://new-partner.example.com/api"
}

### Delete a node (soft delete - sets status to inactive)
DELETE {{baseUrl}}/directory/nodes/{{nodeId}}
Authorization: Bearer {{jwtToken}}
Content-Type: application/json

### List nodes for an organization (with pagination)
GET {{baseUrl}}/directory/organizations/{{organizationId}}/nodes?page=1&pageSize=10
Authorization: Bearer {{jwtToken}}
Content-Type: application/json

### Search nodes for an organization
GET {{baseUrl}}/directory/organizations/{{organizationId}}/nodes?search=production&page=1&pageSize=5
Authorization: Bearer {{jwtToken}}
Content-Type: application/json

### List nodes for an organization (sorted by name ascending)
GET {{baseUrl}}/directory/organizations/{{organizationId}}/nodes?sortBy=name&sortOrder=asc&page=1&pageSize=10
Authorization: Bearer {{jwtToken}}
Content-Type: application/json

### List nodes for an organization (sorted by type)
GET {{baseUrl}}/directory/organizations/{{organizationId}}/nodes?sortBy=type&sortOrder=asc&page=1&pageSize=10
Authorization: Bearer {{jwtToken}}
Content-Type: application/json

### List nodes for an organization (sorted by status)
GET {{baseUrl}}/directory/organizations/{{organizationId}}/nodes?sortBy=status&sortOrder=desc&page=1&pageSize=10
Authorization: Bearer {{jwtToken}}
Content-Type: application/json

### List nodes for an organization (sorted by createdAt descending - newest first)
GET {{baseUrl}}/directory/organizations/{{organizationId}}/nodes?sortBy=createdAt&sortOrder=desc&page=1&pageSize=10
Authorization: Bearer {{jwtToken}}
Content-Type: application/json

### List all nodes (root only)
GET {{baseUrl}}/directory/nodes?page=1&pageSize=10
Authorization: Bearer {{jwtToken}}
Content-Type: application/json

### Search all nodes by name or organization name
GET {{baseUrl}}/directory/nodes?search=production&page=1&pageSize=5
